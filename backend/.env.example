# Flask
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-in-production

# Database
DATABASE_URL=postgresql://shareflow:shareflow_pass@localhost:5432/shareflow

# JWT
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id

# Apple Sign-In
APPLE_CLIENT_ID=your.app.bundle.id
APPLE_TEAM_ID=YOUR_TEAM_ID
APPLE_KEY_ID=YOUR_KEY_ID
APPLE_PRIVATE_KEY_PATH=./apple_private_key.p8

# Google Vision OCR
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json

# Firebase (push notifications)
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# Storage (local dev)
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./uploads
# For S3:
# STORAGE_BACKEND=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_S3_REGION=

# ADL Dashboard (adl_control DB)
ADL_CONTROL_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/adl_control

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Email (Resend — https://resend.com)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL=ADL ShareFlow <noreply@yourdomain.com>
